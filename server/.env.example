# MongoDB Configuration
# RECOMMENDED: MongoDB Atlas (Cloud Database - Free tier available)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/cloudstorage?retryWrites=true&w=majority

# Alternative: Local MongoDB (requires installation)
# MONGO_URI=mongodb://127.0.0.1:27017/cloudstorage

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes
